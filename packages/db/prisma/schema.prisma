// Probe — simplified interview-room schema (two roles: interviewer, interviewee).
// See C:\probe\CLAUDE.md §3 for the domain model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  interviewer
  interviewee
}

enum InterviewStatus {
  scheduled
  interviewer_joined
  candidate_waiting
  active
  completed
  cancelled
  no_show
}

enum Recommendation {
  pending
  hire
  hold
  reject
}

/// A person who can join a room. `id` mirrors the Supabase auth user id when
/// Supabase auth is used; local email/password auth stores a bcrypt hash here.
model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  name         String
  passwordHash String?  @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  username     String?  @unique
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  interviewsAsInterviewer Interview[] @relation("InterviewerInterviews")
  interviewsAsInterviewee Interview[] @relation("IntervieweeInterviews")

  @@map("users")
}

/// A scheduled 1:1 interview session.
model Interview {
  id                  String          @id @default(uuid())
  interviewerId       String          @map("interviewer_id")
  intervieweeId       String          @map("interviewee_id")
  status              InterviewStatus @default(scheduled)
  scheduledAt         DateTime?       @map("scheduled_at")
  timezone            String?
  durationMinutes     Int             @default(60) @map("duration_minutes")
  startedAt           DateTime?       @map("started_at")
  endedAt             DateTime?       @map("ended_at")
  activeQuestionId    String?         @map("active_question_id")
  activeQuestionIndex Int             @default(0) @map("active_question_index")
  candidateInstructions String?       @map("candidate_instructions")
  interviewerNotes    String?         @map("interviewer_notes")
  /// Selected rounds for this interview: 'dsa' | 'sql' | 'system_design'.
  rounds              String[]        @default([])
  /// Public share token — the candidate joins via /join/<shareToken>.
  shareToken          String?         @unique @map("share_token")
  companyName         String?         @map("company_name")
  roleTitle           String?         @map("role_title")
  experienceLevel     String?         @map("experience_level")
  resumeFileName      String?         @map("resume_file_name")
  resumeText          String?         @map("resume_text")
  resumeUploadedAt    DateTime?       @map("resume_uploaded_at")
  resumeAnalysis      Json?           @map("resume_analysis")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  interviewer User @relation("InterviewerInterviews", fields: [interviewerId], references: [id], onDelete: Cascade)
  interviewee User @relation("IntervieweeInterviews", fields: [intervieweeId], references: [id], onDelete: Cascade)

  questions   InterviewQuestion[]
  roomSession RoomSession?
  evaluation  RoomEvaluation?
  rubric      InterviewRubric?
  scorecard   CopilotScorecard?

  @@index([interviewerId])
  @@index([intervieweeId])
  @@map("interviews")
}

/// The Probe "role pack": 6-8 things a strong hire can prove, generated from the
/// role title + JD at interview creation. Human-inspectable, versioned.
/// items: [{ key, title, description, weakSignal, strongSignal }]
model InterviewRubric {
  id          String   @id @default(uuid())
  interviewId String   @unique @map("interview_id")
  roleTitle   String?  @map("role_title")
  jdText      String?  @map("jd_text")
  items       Json     @default("[]")
  version     Int      @default(1)
  source      String   @default("generated") // generated | fallback | manual
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("interview_rubrics")
}

/// Evidence-linked scorecard drafted by the copilot at session end. Assistive only —
/// the interviewer's RoomEvaluation stays the human record.
/// items: [{ key, title, verdict, evidence[], note }]
model CopilotScorecard {
  id          String   @id @default(uuid())
  interviewId String   @unique @map("interview_id")
  summary     String?
  items       Json     @default("[]")
  generatedAt DateTime @default(now()) @map("generated_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("copilot_scorecards")
}

/// A question attached to an interview. `questionId` is polymorphic: it holds
/// either a Postgres Question.id (seed bank) OR a Mongo bank ObjectId (24-hex),
/// so it is intentionally NOT a foreign key.
model InterviewQuestion {
  id          String   @id @default(uuid())
  interviewId String   @map("interview_id")
  questionId  String?  @map("question_id")
  text        String
  setTitle    String?  @map("set_title")
  type        String?
  source      String?
  difficulty  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  interview Interview      @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("interview_questions")
}

/// Reusable question bank (statement, examples, starter code, solution, tests).
model Question {
  id          String   @id @default(uuid())
  title       String
  statement   String?
  description String?
  difficulty  String?
  language    String?
  examples    Json?
  constraints Json?
  starterCode Json?    @map("starter_code")
  codeSnippets Json?   @map("code_snippets")
  hints       Json?
  solution    Json?
  sampleTests Json?    @map("sample_tests")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("questions")
}

/* ------------------------------------------------------------------ *
 * Runtime / room tables (ported from reference manual-sql).
 * ------------------------------------------------------------------ */

model RoomSession {
  id                      String    @id @default(uuid())
  interviewId             String    @unique @map("interview_id")
  status                  String    @default("scheduled")
  interviewerJoinedAt     DateTime? @map("interviewer_joined_at")
  candidateFirstWaitingAt DateTime? @map("candidate_first_waiting_at")
  candidateAdmittedAt     DateTime? @map("candidate_admitted_at")
  startedAt               DateTime? @map("started_at")
  endedAt                 DateTime? @map("ended_at")
  activeQuestionId        String?   @map("active_question_id")
  activeQuestionIndex     Int       @default(0) @map("active_question_index")
  activeQuestionRevealedAt DateTime? @map("active_question_revealed_at")
  /// Which shared surface is live in the room: meet | dsa | sql | design.
  activeSurface           String    @default("meet") @map("active_surface")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  interview    Interview           @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  participants RoomParticipant[]
  events       RoomEvent[]
  snapshots    RoomCodeSnapshot[]
  evaluation   RoomEvaluation?

  @@map("room_sessions")
}

model RoomParticipant {
  id            String    @id @default(uuid())
  roomSessionId String    @map("room_session_id")
  userId        String    @map("user_id")
  role          Role
  admittedAt    DateTime? @map("admitted_at")
  firstJoinedAt DateTime  @default(now()) @map("first_joined_at")
  lastJoinedAt  DateTime  @default(now()) @map("last_joined_at")
  lastSeenAt    DateTime? @map("last_seen_at")
  disconnectedAt DateTime? @map("disconnected_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  roomSession RoomSession @relation(fields: [roomSessionId], references: [id], onDelete: Cascade)

  @@unique([roomSessionId, role, userId])
  @@map("room_participants")
}

model RoomEvent {
  id            String   @id @default(uuid())
  roomSessionId String   @map("room_session_id")
  actorUserId   String?  @map("actor_user_id")
  actorRole     String?  @map("actor_role")
  eventType     String   @map("event_type")
  payload       Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")

  roomSession RoomSession @relation(fields: [roomSessionId], references: [id], onDelete: Cascade)

  @@index([roomSessionId, createdAt])
  @@map("room_events")
}

model RoomCodeSnapshot {
  id            String   @id @default(uuid())
  roomSessionId String   @map("room_session_id")
  interviewId   String   @map("interview_id")
  questionId    String?  @map("question_id")
  language      String   @default("javascript")
  code          String   @default("")
  revision      Int      @default(0)
  updatedByUserId String? @map("updated_by_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  roomSession RoomSession @relation(fields: [roomSessionId], references: [id], onDelete: Cascade)

  @@index([roomSessionId, questionId])
  @@map("room_code_snapshots")
}

model RoomEvaluation {
  id                String         @id @default(uuid())
  roomSessionId     String         @unique @map("room_session_id")
  interviewId       String         @unique @map("interview_id")
  interviewerUserId String         @map("interviewer_user_id")
  score             Int?
  recommendation    Recommendation @default(pending)
  strengths         String[]       @default([])
  concerns          String[]       @default([])
  notes             String?
  payload           Json           @default("{}")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  roomSession RoomSession @relation(fields: [roomSessionId], references: [id], onDelete: Cascade)
  interview   Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewerUserId])
  @@map("room_evaluations")
}
