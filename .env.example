# --- Database (Postgres / Supabase) ---
DATABASE_URL="postgresql://user:password@localhost:5432/probe?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/probe?schema=public"

# --- Supabase auth ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Expert (realtime backend) ---
EXPERT_HOST="::"
EXPERT_PORT="3004"
# Platform-injected port (Render/Heroku/etc. set this automatically in production —
# leave unset locally so EXPERT_PORT above is used instead).
# PORT=""
FRONTEND_URL="http://localhost:3000"          # interviewee app origin (CORS allowlist)
COMPANY_FRONTEND_URL="http://localhost:3003"  # interviewer app origin (CORS allowlist)
# Extra CORS-allowed origins — set these to your deployed URLs in production.
NEXT_PUBLIC_APP_URL=""            # interviewee production URL, e.g. https://probe-interviewee.vercel.app
NEXT_PUBLIC_COMPANY_APP_URL=""    # interviewer production URL, e.g. https://probe-interviewer.vercel.app
# HMAC secret used to sign socket auth tokens. MUST be a real random secret in
# production — falls back to an insecure dev default ("probe-dev-secret") if unset.
AUTH_SECRET=""

# --- Clients ---
NEXT_PUBLIC_EXPERT_URL="http://localhost:3004"
# Interviewer-only: base URL of the interviewee app, used to build candidate join links.
NEXT_PUBLIC_CANDIDATE_URL="http://localhost:3000"
# JSON array of RTCIceServer; defaults to Google STUN if unset
NEXT_PUBLIC_ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"}]'

# --- Judge0 (code execution) ---
# Self-hosted: JUDGE0_API_URL=http://localhost:2358 (leave key blank).
# RapidAPI:    JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com + JUDGE0_API_KEY=<key>.
JUDGE0_API_URL=""
JUDGE0_API_KEY=""
JUDGE0_PROVIDER="auto"

# --- Probe copilot (LLM, optional — falls back to a deterministic rubric if unset) ---
# Provider chain: Gemini -> xAI -> Groq. Set any one key to enable the copilot.
GOOGLE_GENERATIVE_AI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
XAI_API_KEY=""
XAI_MODEL="grok-3-mini"
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-120b"

# --- Mongo question bank (optional — falls back to the seeded Postgres bank if unset) ---
MONGODB_URI=""
